# Frontend Environment Variables Template
# Copy this to .env and fill with your actual values

# API Configuration
VITE_API_URL=https://freelance-marketplace-production.up.railway.app/api/

# WebSocket Configuration
VITE_WS_URL=wss://freelance-marketplace-production.up.railway.app/ws

# Application Settings
VITE_APP_NAME=Freelance Marketplace
VITE_APP_VERSION=1.0.0

# Logging (dev, test, prod)
VITE_LOG_LEVEL=debug
